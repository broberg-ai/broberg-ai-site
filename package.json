{
  "name": "broberg-ai-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server.tsx",
    "build:client": "vite build",
    "build": "bun run build:client",
    "start": "NODE_ENV=production bun run src/server.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "gate:text": "cms check-text --dir src --allowlist .cms-check-text-allowlist",
    "gate:coverage": "cms coverage --schema .cms-coverage-schema.json --url https://broberg.ai --pages /,/losninger,/losninger/ai-integration,/losninger/websites,/losninger/webshops,/losninger/platforme,/universet,/flagskibe,/inline-redigering,/own-your-own-data,/sanne-andersen,/tre-arkitekturer-agent-hukommelse,/x-rt-platform,/fysio-dk-sport,/fysio-dk-aalborg,/chat-med-dit-website,/sft-vs-prompt-rag-trail,/bevis-ikke-loefter,/design-i-højere-luftlag,/fra-forfatter-til-redaktoer --ignore metaTitle,metaDescription,ogTitle,ogDescription,siteName,siteTitle,siteDescription,navCtaUrl,ctaPrimaryUrl,ctaSecondaryUrl,contactEmail,order,readTime,url,label --baseline .cms-coverage-baseline"
  },
  "dependencies": {
    "@broberg/cms-chat-client": "^0.4.16",
    "@broberg/cms-inline-edit": "^0.4.19",
    "@broberg/forms-turnstile": "^0.1.0",
    "hono": "^4.6.14",
    "marked": "^18.0.5",
    "preact": "^10.25.4",
    "preact-render-to-string": "^6.5.13"
  },
  "devDependencies": {
    "@broberg/lens-engine": "^0.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.1.14",
    "@webhouse/cms-cli": "^0.4.22",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.7"
  }
}
