# broberg.ai — Stack B app env. Real values land via the deploy secret store,
# NEVER via intercom. cms (webhouse.app, org BROBERG-AI) provides the two creds.

# Where the local content store (ICD writes + backfill) lives. MUST be a
# persistent volume on Fly so pushed content survives container restart.
CONTENT_DIR=./.content-store

# cms read-API — used ONLY for the initial backfill / resync on first boot.
READ_API_BASE=https://webhouse.app/api/cms
CMS_SITE=broberg-ai
# Read-only token scoped to broberg-ai (seed/resync only, not steady-state).
WH_READ_TOKEN=

# Shared HMAC secret for verifying ICD content-push POSTs to /icd.
REVALIDATE_SECRET=

# Reject ICD documents whose signed body.timestamp is older than this (ms).
# Optional anti-replay hardening on top of the HMAC. 0 disables.
ICD_MAX_AGE_MS=300000

PORT=3000
